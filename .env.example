# Required — your ClawPump API key (get one at https://agents.clawpump.tech/developers)
CLAWPUMP_API_KEY=your_api_key_here

# Agent wallet address (used in swap and strategy examples)
AGENT_WALLET=your_solana_wallet_address

# Monitor & Exit strategy config
WATCHED_TOKEN_MINT=token_mint_to_monitor
ENTRY_PRICE=0.00

# Privy embedded wallet config (for server-side signing — see examples/swap-with-privy.ts)
PRIVY_WALLET_ID=your_privy_wallet_id
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
